# Copy this file to .env and fill in your actual values

# Server port and host configuration
MERC_PORT=18080
MERC_HOST=0.0.0.0

# Frontend origin allowed to call this API with cookies.
# Use a comma-separated list for multiple origins, for example:
# MERC_FRONTEND_DOMAIN=http://localhost:5173,https://app.example.com
MERC_FRONTEND_DOMAIN=http://localhost:5173

# sqlite, pg, mysql
MERC_DATABASE_TYPE=sqlite
MERC_DATABASE_URL=./data.db

MERC_SESSION_SECRET=your_super_secret_session_key_change_this_in_production
MERC_SESSION_MAX_AGE=1209600000  # 14 days
# For true cross-site HTTPS deployments, use:
# MERC_SESSION_COOKIE_SAME_SITE=none
# MERC_SESSION_COOKIE_SECURE=true
MERC_SESSION_COOKIE_SAME_SITE=lax
MERC_SESSION_COOKIE_SECURE=false

# Optional config file path.
# MERC_CONFIG_FILE=./config/config.yaml

# Node / agent settings.
# MERC_NODE_NAME=merc-node-1
# MERC_NODE_KEY=merc-node-1
# MERC_AGENT_SERVER_URL=http://localhost:18080
# MERC_AGENT_TOKEN=merc_agent_join_token
MERC_AGENT_DATA_DIR=./merc-agent
MERC_AGENT_HEARTBEAT_INTERVAL=15s
MERC_AGENT_POLL_INTERVAL=5s

# GitHub Actions runner settings.
# Use "latest" to resolve the newest actions/runner release at install time,
# or pin a specific version like 2.329.0.
MERC_RUNNER_DEFAULT_VERSION=latest

# Cloud Storage (AWS S3)
MERC_AWS_ACCESS_KEY_ID=your_aws_access_key
MERC_AWS_SECRET_ACCESS_KEY=your_aws_secret_key
MERC_AWS_REGION=us-east-1
MERC_AWS_S3_BUCKET=your-bucket-name
